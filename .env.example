# --- Configuration du site (copiez ce fichier en ".env" et remplissez vos valeurs) ---
# Le fichier .env n'est JAMAIS versionne (il contient vos secrets).

# Base de donnees MySQL / MariaDB (LOCALE a l'hebergeur, ex. o2switch cPanel).
# Creez la base + l'utilisateur dans cPanel -> "Bases de donnees MySQL".
DB_HOST=localhost
DB_USER=prefixe_utilisateur
DB_PASSWORD=mot_de_passe_mysql
DB_NAME=prefixe_base

# Mot de passe du tableau de bord admin ( /admin.html )
ADMIN_TOKEN=manuelajorel2027
