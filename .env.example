# --- Configuration du site (copiez ce fichier en ".env" et remplissez vos valeurs) ---
# Le fichier .env n'est JAMAIS versionne (il contient vos secrets).

# Chaine de connexion MongoDB Atlas
# (Atlas -> votre cluster -> Connect -> Drivers -> copiez l'URI, remplacez <password>)
MONGODB_URI=mongodb+srv://UTILISATEUR:MOTDEPASSE@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# (Optionnel) Nom de la base de donnees
MONGODB_DB=mariage

# Mot de passe du tableau de bord admin ( /admin.html )
ADMIN_TOKEN=choisissez-un-mot-de-passe-secret
